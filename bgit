#!/usr/bin/env bash
#
# BGit - Better Git
# A cleaner, friendlier wrapper around git with auto merge-conflict resolution.
#
# Author: Connor Gentile
# Repo:   https://github.com/connorgentile113-png/BGit
# License: MIT
#

set -uo pipefail

VERSION="1.2.0"
UPDATE_URL="https://raw.githubusercontent.com/connorgentile113-png/BGit/main/bgit"

# ─── Colors (respect NO_COLOR and non-tty output) ──────────────────────────
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    PURPLE='\033[0;35m'
    CYAN='\033[0;36m'
    GRAY='\033[0;90m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' PURPLE='' CYAN='' GRAY='' BOLD='' DIM='' NC=''
fi

# ─── Icons ──────────────────────────────────────────────────────────────────
CHECK="✅"
CROSS="❌"
WARN="⚠️"
INFO="ℹ️"
ROCKET="🚀"
BRANCH_ICON="🌿"
CONFLICT_ICON="💥"
PUSH_ICON="⬆️"
PULL_ICON="⬇️"
TAG_ICON="🏷️"
CLEAN_ICON="🧹"
UPDATE_ICON="🔄"

# ─── Print Helpers ──────────────────────────────────────────────────────────
print_info()    { echo -e "${BLUE}${INFO}${NC}  $1"; }
print_success() { echo -e "${GREEN}${CHECK}${NC} $1"; }
print_warn()    { echo -e "${YELLOW}${WARN}${NC}  $1"; }
print_error()   { echo -e "${RED}${CROSS}${NC} $1" >&2; }
print_header()  { echo -e "\n${BOLD}${PURPLE}${ROCKET} $1${NC}\n"; }
print_step()    { echo -e "  ${CYAN}→${NC} $1"; }
print_dim()     { echo -e "  ${DIM}$1${NC}"; }

# ─── Utilities ──────────────────────────────────────────────────────────────
require_git() {
    if ! command -v git &>/dev/null; then
        print_error "Git is not installed on this system."
        print_info  "Install git first:  https://git-scm.com/downloads"
        exit 1
    fi
}

require_repo() {
    if ! in_git_repo; then
        print_error "Not inside a Git repository."
        print_info  "Run ${BOLD}bgit init${NC} to create one."
        exit 1
    fi
}

in_git_repo() {
    git rev-parse --is-inside-work-tree &>/dev/null
}

current_branch() {
    git branch --show-current 2>/dev/null || echo "detached"
}

conflicted_files() {
    git diff --name-only --diff-filter=U 2>/dev/null
}

has_conflicts() {
    local count
    count=$(git diff --name-only --diff-filter=U 2>/dev/null | wc -l)
    [[ "$count" -gt 0 ]]
}

git_quiet() {
    git "$@" 2>/dev/null
}

# Returns ahead,behind for current branch vs its upstream (empty if none)
ahead_behind() {
    local up
    up=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
    [[ -z "$up" ]] && return 1
    local a b
    a=$(git rev-list --count '@{u}..HEAD' 2>/dev/null || echo 0)
    b=$(git rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)
    echo "${a} ${b}"
}

# ─── Command: init ──────────────────────────────────────────────────────────
cmd_init() {
    print_header "Initializing a new Git repository"
    if in_git_repo; then
        print_warn "This directory is already a Git repository — nothing to do."
        print_dim "  Run ${BOLD}bgit status${NC} to see what's going on in here."
        return 0
    fi
    git init
    print_success "Repository initialized in $(pwd)"
    print_step "Setting up sensible defaults..."
    git config init.defaultBranch main 2>/dev/null || true
    git config pull.rebase false 2>/dev/null || true
    print_success "Defaults configured."
    echo
    echo -e "  ${BOLD}${GREEN}You're all set!${NC} Here's where to go next:"
    print_dim "  bgit add .                      — stage your files"
    print_dim "  bgit commit -m \"Initial commit\"  — save your first snapshot"
    echo
}

# ─── Command: status ────────────────────────────────────────────────────────
cmd_status() {
    require_repo
    local compact=false
    [[ "${1:-}" == "-s" || "${1:-}" == "--short" ]] && compact=true

    local branch ab a="" b=""
    branch=$(current_branch)

    if [[ "$compact" == true ]]; then
        local staged modified untracked
        staged=$(git diff --cached --name-only 2>/dev/null | wc -l)
        modified=$(git diff --name-only 2>/dev/null | wc -l)
        untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l)
        if ab=$(ahead_behind); then read -r a b <<< "$ab"; fi
        local ab_str=""
        [[ -n "$a" ]] && [[ "$a" -gt 0 || "$b" -gt 0 ]] && ab_str=" ${PUSH_ICON}${a} ${PULL_ICON}${b}"
        echo -e "${BRANCH_ICON} ${BOLD}${branch}${NC}${ab_str}  ${GREEN}+${staged}${NC} ${YELLOW}~${modified}${NC} ${GRAY}?${untracked}${NC}"
        has_conflicts && echo -e "${RED}${CONFLICT_ICON} $(conflicted_files | wc -l) conflict(s)${NC}"
        return 0
    fi

    print_header "Repository Status"
    echo -e "  ${BRANCH_ICON} Branch: ${BOLD}${branch}${NC}"

    if ab=$(ahead_behind); then
        read -r a b <<< "$ab"
        if [[ "$a" -gt 0 ]] || [[ "$b" -gt 0 ]]; then
            echo -e "  ${PUSH_ICON} Ahead by ${BOLD}${a}${NC}  ${PULL_ICON} Behind by ${BOLD}${b}${NC}"
        else
            print_success "Up to date with remote."
        fi
    else
        print_warn "No upstream branch configured."
    fi
    echo

    local staged
    staged=$(git diff --cached --name-only 2>/dev/null)
    if [[ -n "$staged" ]]; then
        echo -e "  ${GREEN}${BOLD}Staged files:${NC}"
        while IFS= read -r f; do
            local stat
            stat=$(git diff --cached --numstat -- "$f" 2>/dev/null | awk '{printf "+%s -%s", $1, $2}')
            echo -e "    ${GREEN}+${NC} $f  ${DIM}${stat}${NC}"
        done <<< "$staged"
        echo
    fi

    local modified
    modified=$(git diff --name-only 2>/dev/null)
    if [[ -n "$modified" ]]; then
        echo -e "  ${YELLOW}${BOLD}Modified (unstaged):${NC}"
        while IFS= read -r f; do
            local stat
            stat=$(git diff --numstat -- "$f" 2>/dev/null | awk '{printf "+%s -%s", $1, $2}')
            echo -e "    ${YELLOW}~${NC} $f  ${DIM}${stat}${NC}"
        done <<< "$modified"
        echo
    fi

    local untracked
    untracked=$(git ls-files --others --exclude-standard 2>/dev/null)
    if [[ -n "$untracked" ]]; then
        echo -e "  ${GRAY}${BOLD}Untracked:${NC}"
        while IFS= read -r f; do
            echo -e "    ${GRAY}?${NC} $f"
        done <<< "$untracked"
        echo
    fi

    if has_conflicts; then
        echo -e "  ${RED}${BOLD}${CONFLICT_ICON} Conflicted files:${NC}"
        conflicted_files | while IFS= read -r f; do
            echo -e "    ${RED}!${NC} $f"
        done
        echo
        print_warn "You have unresolved merge conflicts."
        print_info "Run ${BOLD}bgit resolve${NC} to auto-resolve them."
        return
    fi

    if [[ -z "$staged" ]] && [[ -z "$modified" ]] && [[ -z "$untracked" ]]; then
        print_success "Nothing to see here — working tree is clean. 🎉"
    fi
}

# ─── Command: diff ──────────────────────────────────────────────────────────
cmd_diff() {
    require_repo
    local staged=false
    [[ "${1:-}" == "--staged" || "${1:-}" == "--cached" ]] && staged=true

    print_header "$([[ "$staged" == true ]] && echo "Staged Diff" || echo "Working Tree Diff")"

    local summary
    if [[ "$staged" == true ]]; then
        summary=$(git diff --cached --stat 2>/dev/null)
    else
        summary=$(git diff --stat 2>/dev/null)
    fi

    if [[ -z "$summary" ]]; then
        print_info "No changes to show."
        return 0
    fi

    echo "$summary" | sed -E "s/^(.*\|.*\+.*)$/  \1/" | while IFS= read -r line; do
        if [[ "$line" =~ \| ]]; then
            echo -e "  ${CYAN}${line}${NC}"
        else
            echo -e "  ${DIM}${line}${NC}"
        fi
    done
    echo
    print_info "Run ${BOLD}git diff$([[ "$staged" == true ]] && echo " --cached")${NC} for the full line-by-line diff."
}

# ─── Command: add ───────────────────────────────────────────────────────────
cmd_add() {
    require_git
    require_repo

    local target="${1:-.}"

    if [[ "$target" == "." || "$target" == "--all" || "$target" == "-A" ]]; then
        print_header "Staging all changes"
        git add -A
        local count
        count=$(git diff --cached --name-only | wc -l)
        print_success "Staged ${count} file(s)."
    else
        print_header "Staging: $target"
        if git add "$target" 2>/dev/null; then
            print_success "Staged: $target"
        else
            print_error "Could not stage: $target"
            exit 1
        fi
    fi
}

# ─── Command: commit ────────────────────────────────────────────────────────
cmd_commit() {
    require_git
    require_repo

    local message=""
    local auto_stage=false
    local choice=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -m|--message) message="$2"; shift 2 ;;
            -a|--all)     auto_stage=true; shift ;;
            *)
                [[ -z "$message" ]] && message="$1"
                shift
                ;;
        esac
    done

    local staged_count
    staged_count=$(git diff --cached --name-only 2>/dev/null | wc -l)
    if [[ "$staged_count" -eq 0 ]] || [[ "$auto_stage" == true ]]; then
        print_step "Auto-staging all changes..."
        git add -A
        staged_count=$(git diff --cached --name-only 2>/dev/null | wc -l)
    fi

    if [[ "$staged_count" -eq 0 ]]; then
        print_info "Nothing staged to commit — working tree is clean."
        return 0
    fi

    if [[ -z "$message" ]]; then
        print_step "No commit message provided — generating one..."
        message=$(generate_commit_message)
        print_info "Generated message: ${BOLD}\"$message\"${NC}"
        echo
        read -rp "$(echo -e "${BLUE}${INFO}${NC}  Use this message? [Y/n/edit] ")" choice
        choice=${choice:-Y}
        case "${choice,,}" in
            y|yes) ;;
            e|edit) read -rp "Enter your commit message: " message ;;
            *) read -rp "Enter your commit message: " message ;;
        esac
    fi

    print_header "Committing"
    if git commit -m "$message"; then
        print_success "Committed successfully!"
        print_dim "  $(git log -1 --oneline)"
    else
        print_error "Commit failed."
        exit 1
    fi
}

# ─── Command: amend ─────────────────────────────────────────────────────────
cmd_amend() {
    require_git
    require_repo

    if ! git log -1 &>/dev/null; then
        print_error "No commits yet — nothing to amend."
        exit 1
    fi

    local message=""
    local no_edit=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -m|--message) message="$2"; shift 2 ;;
            --no-edit) no_edit=true; shift ;;
            *) shift ;;
        esac
    done

    # Stage any pending changes too — amend usually means "fold this in"
    local staged_count
    staged_count=$(git diff --cached --name-only 2>/dev/null | wc -l)
    local unstaged_count
    unstaged_count=$(git diff --name-only 2>/dev/null | wc -l)
    if [[ "$staged_count" -eq 0 ]] && [[ "$unstaged_count" -gt 0 ]]; then
        print_step "Staging modified files for amend..."
        git add -u
    fi

    print_header "Amending last commit"
    print_dim "  Was: $(git log -1 --oneline)"

    if [[ -n "$message" ]]; then
        git commit --amend -m "$message"
    elif [[ "$no_edit" == true ]]; then
        git commit --amend --no-edit
    else
        git commit --amend --no-edit
    fi

    print_success "Amended."
    print_dim "  Now: $(git log -1 --oneline)"
    print_warn "If this commit was already pushed, you'll need: bgit push --force"
}

# Generate a simple commit message from the diff
generate_commit_message() {
    local staged
    staged=$(git diff --cached --name-only 2>/dev/null)

    local added=0 modified=0 deleted=0 renamed=0
    while IFS= read -r f; do
        local status
        status=$(git diff --cached --name-status -- "$f" 2>/dev/null | head -1 | cut -c1)
        case "$status" in
            A) added=$((added + 1)) ;;
            M) modified=$((modified + 1)) ;;
            D) deleted=$((deleted + 1)) ;;
            R) renamed=$((renamed + 1)) ;;
            *) modified=$((modified + 1)) ;;
        esac
    done <<< "$staged"

    local parts=()
    [[ $added -gt 0 ]]    && parts+=("add $added file(s)")
    [[ $modified -gt 0 ]] && parts+=("update $modified file(s)")
    [[ $deleted -gt 0 ]]  && parts+=("remove $deleted file(s)")
    [[ $renamed -gt 0 ]]  && parts+=("rename $renamed file(s)")

    local action="update"
    if [[ $added -gt 0 ]] && [[ $modified -eq 0 ]] && [[ $deleted -eq 0 ]] && [[ $renamed -eq 0 ]]; then
        action="add"
    elif [[ $deleted -gt 0 ]] && [[ $added -eq 0 ]] && [[ $modified -eq 0 ]] && [[ $renamed -eq 0 ]]; then
        action="remove"
    fi

    local scope=""
    scope=$(echo "$staged" | grep -F / | sed 's|/.*||' | sort | uniq -c | sort -rn | head -1 | awk '{print $2}')
    [[ -n "$scope" ]] && scope="($scope)"

    echo "${action}${scope}: $(IFS=', '; echo "${parts[*]}")"
}

# ─── Command: push ──────────────────────────────────────────────────────────
cmd_push() {
    require_git
    require_repo

    local force=false
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            *) args+=("$1"); shift ;;
        esac
    done

    local upstream
    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")

    if [[ -z "$upstream" ]]; then
        local branch
        branch=$(current_branch)
        print_header "Setting up remote tracking"
        print_step "No upstream found for '${branch}'. Pushing and setting upstream to 'origin/${branch}'..."
        if git push -u origin "$branch" "${args[@]}"; then
            print_success "Pushed and tracking 'origin/${branch}'."
        else
            print_error "Push failed."
            exit 1
        fi
        return
    fi

    local ahead
    ahead=$(git rev-list --count '@{u}..HEAD' 2>/dev/null || echo 0)
    if [[ "$ahead" -eq 0 ]] && [[ "$force" == false ]]; then
        print_info "Already up to date — nothing to push."
        return 0
    fi

    print_header "Pushing to ${upstream}"
    local result=0
    if [[ "$force" == true ]]; then
        print_warn "Force push enabled (using --force-with-lease for safety)."
        git push --force-with-lease "${args[@]}" || result=$?
    else
        git push "${args[@]}" || result=$?
    fi

    if [[ "$result" -eq 0 ]]; then
        print_success "Pushed ${ahead} commit(s) successfully!"
    else
        print_error "Push failed."
        exit 1
    fi
}

# ─── Command: pull ──────────────────────────────────────────────────────────
cmd_pull() {
    require_git
    require_repo

    local upstream
    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")

    if [[ -z "$upstream" ]]; then
        print_error "No upstream branch is configured for '$(current_branch)'."
        print_info  "Try pushing first:  bgit push"
        exit 1
    fi

    print_header "Pulling from ${upstream}"

    local stashed=false
    if ! git diff --quiet || ! git diff --cached --quiet; then
        print_warn "You have uncommitted changes. Stashing them temporarily..."
        git stash push -m "bgit-auto-stash-$(date +%s)" >/dev/null 2>&1
        stashed=true
    fi

    if git pull --no-rebase; then
        print_success "Pull completed successfully!"
    else
        print_warn "Pull resulted in conflicts."
        if has_conflicts; then
            print_info "Attempting auto-resolve..."
            cmd_resolve --auto
        else
            print_error "Pull failed."
            if [[ "$stashed" == true ]]; then
                print_step "Restoring your stashed changes..."
                git stash pop >/dev/null 2>&1
            fi
            exit 1
        fi
    fi

    if [[ "$stashed" == true ]]; then
        print_step "Restoring your stashed changes..."
        if git stash pop; then
            print_success "Changes restored."
        else
            print_warn "Could not auto-restore stash. Run ${BOLD}git stash pop${NC} manually."
        fi
    fi
}

# ─── Command: merge ─────────────────────────────────────────────────────────
cmd_merge() {
    require_git
    require_repo

    if [[ $# -eq 0 ]]; then
        print_error "Please specify a branch to merge."
        print_info  "Usage: bgit merge <branch>"
        exit 1
    fi

    local target="$1"
    shift
    local strategy=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ours|--theirs|--union) strategy="$1"; shift ;;
            *) shift ;;
        esac
    done

    print_header "Merging '${target}' into '$(current_branch)'"

    local stashed=false
    if ! git diff --quiet || ! git diff --cached --quiet; then
        print_warn "Working tree is not clean. Stashing changes..."
        git stash push -m "bgit-merge-stash-$(date +%s)" >/dev/null 2>&1
        stashed=true
    fi

    if git merge "$target" 2>&1; then
        print_success "Merge completed cleanly!"
    else
        print_warn "Merge produced conflicts."
        if [[ -n "$strategy" ]]; then
            print_info "Auto-resolving with strategy: ${strategy}"
            resolve_with_strategy "$strategy"
            if git commit --no-edit 2>/dev/null; then
                print_success "Conflicts resolved and merge committed!"
            else
                print_warn "Conflicts resolved but commit needs your attention."
                print_info  "Run: bgit commit"
            fi
        else
            print_info  "Run ${BOLD}bgit resolve${NC} to auto-resolve, or"
            print_info  "  bgit resolve --ours   (keep your changes)"
            print_info  "  bgit resolve --theirs (keep incoming changes)"
        fi
    fi

    if [[ "$stashed" == true ]]; then
        print_step "Restoring stashed changes..."
        git stash pop 2>/dev/null && print_success "Changes restored." || true
    fi
}

# ─── Command: resolve ───────────────────────────────────────────────────────
resolve_with_strategy() {
    local strategy="$1"
    local files
    files=$(conflicted_files)
    [[ -z "$files" ]] && return 0

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        case "$strategy" in
            --ours)
                git checkout --ours "$file" 2>/dev/null
                print_step "Resolved (ours):   $file"
                ;;
            --theirs)
                git checkout --theirs "$file" 2>/dev/null
                print_step "Resolved (theirs): $file"
                ;;
            --union)
                if [[ -f "$file" ]]; then
                    git merge-file --union -p "$file" "$file" "$file" 2>/dev/null > "${file}.resolved" || true
                    [[ -f "${file}.resolved" ]] && mv "${file}.resolved" "$file"
                fi
                print_step "Resolved (union):  $file"
                ;;
        esac
        git add "$file" 2>/dev/null
    done <<< "$files"
}

cmd_resolve() {
    require_git
    require_repo

    local strategy=""
    local auto=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ours) strategy="--ours"; shift ;;
            --theirs) strategy="--theirs"; shift ;;
            --union) strategy="--union"; shift ;;
            --auto) auto=true; shift ;;
            *) shift ;;
        esac
    done

    print_header "Resolving Merge Conflicts"

    if ! has_conflicts; then
        print_success "No conflicts detected. You're all clean!"
        return 0
    fi

    local files
    files=$(conflicted_files)
    local count
    count=$(echo "$files" | wc -l)

    echo -e "  ${RED}${CONFLICT_ICON}${NC} Found ${BOLD}${count}${NC} conflicted file(s):"
    while IFS= read -r f; do
        [[ -n "$f" ]] && echo -e "    ${RED}!${NC} $f"
    done <<< "$files"
    echo

    local choice="" fchoice=""

    if [[ -z "$strategy" ]] && [[ "$auto" == false ]]; then
        echo -e "  ${BOLD}Choose a resolution strategy:${NC}"
        echo -e "    ${CYAN}1${NC}) Keep MY changes        (--ours)"
        echo -e "    ${CYAN}2${NC}) Keep INCOMING changes   (--theirs)"
        echo -e "    ${CYAN}3${NC}) Combine both            (--union)"
        echo -e "    ${CYAN}4${NC}) Decide per file"
        echo -e "    ${CYAN}5${NC}) Cancel"
        echo
        read -rp "$(echo -e "${BLUE}${INFO}${NC}  Select [1-5]: ")" choice

        case "$choice" in
            1) strategy="--ours" ;;
            2) strategy="--theirs" ;;
            3) strategy="--union" ;;
            4)
                while IFS= read -r f; do
                    [[ -z "$f" ]] && continue
                    echo
                    print_info "File: $f"
                    echo -e "    ${CYAN}1${NC}) Keep mine"
                    echo -e "    ${CYAN}2${NC}) Keep incoming"
                    echo -e "    ${CYAN}3${NC}) Combine"
                    echo -e "    ${CYAN}4${NC}) Skip (leave conflicted)"
                    read -rp "  Choice [1-4]: " fchoice
                    case "$fchoice" in
                        1) git checkout --ours "$f" 2>/dev/null; git add "$f"; print_step "Resolved (ours): $f" ;;
                        2) git checkout --theirs "$f" 2>/dev/null; git add "$f"; print_step "Resolved (theirs): $f" ;;
                        3)
                            if [[ -f "$f" ]]; then
                                git merge-file --union -p "$f" "$f" "$f" 2>/dev/null > "${f}.resolved" || true
                                [[ -f "${f}.resolved" ]] && mv "${f}.resolved" "$f"
                            fi
                            git add "$f"
                            print_step "Resolved (union): $f"
                            ;;
                        4) print_warn "Skipped: $f" ;;
                    esac
                done <<< "$files"
                if has_conflicts; then
                    print_warn "Some files are still conflicted."
                    return 0
                fi
                print_success "All conflicts resolved!"
                print_info "Run ${BOLD}bgit commit${NC} to finalize."
                return 0
                ;;
            *) print_warn "Cancelled."; return 0 ;;
        esac
    fi

    if [[ "$auto" == true ]] && [[ -z "$strategy" ]]; then
        strategy="--ours"
        print_step "Auto-mode: defaulting to keep your changes (--ours)."
    fi

    [[ -n "$strategy" ]] && resolve_with_strategy "$strategy"

    if has_conflicts; then
        print_warn "Some files could not be auto-resolved."
        print_info  "You may need to resolve them manually."
    else
        print_success "All conflicts resolved!"
        echo
        print_info "Finalize the merge with:  bgit commit"
    fi
}

# ─── Command: clone ─────────────────────────────────────────────────────────
cmd_clone() {
    require_git
    if [[ $# -eq 0 ]]; then
        print_error "Please provide a repository URL."
        print_info  "Usage: bgit clone <url> [directory]"
        exit 1
    fi

    local url="$1"
    shift
    local dir="${1:-}"

    print_header "Cloning Repository"
    print_step "URL: $url"
    [[ -n "$dir" ]] && print_step "Target: $dir"

    if [[ -n "$dir" ]]; then
        if git clone "$url" "$dir"; then
            print_success "Cloned into '${dir}'!"
            cd "$dir" || return
            print_info "Now in $(pwd)"
        fi
    else
        if git clone "$url"; then
            local repo_name
            repo_name=$(basename "$url" .git)
            print_success "Cloned into '${repo_name}'!"
        fi
    fi
}

# ─── Command: branch ────────────────────────────────────────────────────────
cmd_branch() {
    require_git
    require_repo

    if [[ $# -eq 0 ]]; then
        print_header "Branches"
        local current
        current=$(current_branch)
        git for-each-ref --format='%(refname:short)' refs/heads/ | while IFS= read -r b; do
            local upstream a=0 bnum=0 abstr=""
            upstream=$(git rev-parse --abbrev-ref --symbolic-full-name "${b}@{u}" 2>/dev/null || echo "")
            if [[ -n "$upstream" ]]; then
                a=$(git rev-list --count "${upstream}..${b}" 2>/dev/null || echo 0)
                bnum=$(git rev-list --count "${b}..${upstream}" 2>/dev/null || echo 0)
                [[ "$a" -gt 0 || "$bnum" -gt 0 ]] && abstr=" ${DIM}(${PUSH_ICON}${a} ${PULL_ICON}${bnum})${NC}"
            fi
            if [[ "$b" == "$current" ]]; then
                echo -e "  ${GREEN}${BRANCH_ICON} * ${BOLD}${b}${NC}${abstr}"
            else
                echo -e "  ${GRAY}   ${b}${NC}${abstr}"
            fi
        done
        return
    fi

    local action="$1"
    local name="${2:-}"

    case "$action" in
        new|create)
            if [[ -z "$name" ]]; then
                print_error "Please provide a branch name."
                return 1
            fi
            print_header "Creating branch '${name}'"
            git checkout -b "$name"
            print_success "On branch '${name}'"
            ;;
        delete|rm)
            if [[ -z "$name" ]]; then
                print_error "Please provide a branch name."
                return 1
            fi
            print_header "Deleting branch '${name}'"
            git branch -d "$name"
            print_success "Deleted branch '${name}'"
            ;;
        switch|checkout)
            if [[ -z "$name" ]]; then
                print_error "Please provide a branch name."
                return 1
            fi
            print_header "Switching to branch '${name}'"
            git checkout "$name"
            print_success "Now on branch '${name}'"
            ;;
        *)
            print_error "Unknown branch action: $action"
            print_info  "Usage: bgit branch [new|delete|switch] [name]"
            ;;
    esac
}

# ─── Command: recent (recently visited branches) ───────────────────────────
cmd_recent() {
    require_git
    require_repo

    local count="${1:-8}"
    print_header "Recently Visited Branches"

    git reflog show --pretty='%gs' 2>/dev/null \
        | grep -oE 'checkout: moving from [^ ]+ to [^ ]+' \
        | awk '{print $NF}' \
        | awk '!seen[$0]++' \
        | head -n "$count" \
        | while IFS= read -r b; do
            if [[ "$b" == "$(current_branch)" ]]; then
                echo -e "  ${GREEN}${BRANCH_ICON} * ${BOLD}${b}${NC} ${DIM}(current)${NC}"
            else
                echo -e "  ${GRAY}   ${b}${NC}"
            fi
        done

    echo
    print_info "Switch with: ${BOLD}bgit branch switch <name>${NC}"
}

# ─── Command: log ───────────────────────────────────────────────────────────
cmd_log() {
    require_git
    require_repo

    local count="${1:-15}"
    print_header "Recent Commits"
    git log --oneline --graph --decorate -n "$count" | while IFS= read -r line; do
        echo -e "  ${CYAN}${line}${NC}"
    done
}

# ─── Command: stash ─────────────────────────────────────────────────────────
cmd_stash() {
    require_git
    require_repo

    local action="${1:-list}"

    case "$action" in
        save|push|"")
            print_header "Stashing changes"
            git stash push -m "bgit-stash-$(date +%Y%m%d-%H%M%S)"
            print_success "Changes stashed."
            ;;
        pop)
            print_header "Popping stash"
            git stash pop
            print_success "Stash applied."
            ;;
        list)
            print_header "Stash list"
            local stashes
            stashes=$(git stash list)
            if [[ -z "$stashes" ]]; then
                print_info "No stashes found."
            else
                echo "$stashes"
            fi
            ;;
        drop)
            git stash drop "${2:-0}"
            print_success "Stash dropped."
            ;;
    esac
}

# ─── Command: tag ───────────────────────────────────────────────────────────
cmd_tag() {
    require_git
    require_repo

    if [[ $# -eq 0 ]]; then
        print_header "Tags"
        local tags
        tags=$(git tag --sort=-creatordate 2>/dev/null)
        if [[ -z "$tags" ]]; then
            print_info "No tags yet."
            print_dim "  bgit tag new v1.0.0  — create one"
        else
            echo "$tags" | while IFS= read -r t; do
                local msg
                msg=$(git tag -l --format='%(subject)' "$t" 2>/dev/null)
                echo -e "  ${TAG_ICON} ${BOLD}${t}${NC}${msg:+  ${DIM}${msg}${NC}}"
            done
        fi
        return
    fi

    local action="$1"
    local name="${2:-}"

    case "$action" in
        new|create)
            if [[ -z "$name" ]]; then
                print_error "Please provide a tag name."
                return 1
            fi
            local msg=""
            read -rp "$(echo -e "${BLUE}${INFO}${NC}  Tag message (optional): ")" msg
            print_header "Creating tag '${name}'"
            if [[ -n "$msg" ]]; then
                git tag -a "$name" -m "$msg"
            else
                git tag "$name"
            fi
            print_success "Tagged current commit as '${name}'"
            print_dim "  Push it with: bgit push origin ${name}"
            ;;
        delete|rm)
            if [[ -z "$name" ]]; then
                print_error "Please provide a tag name."
                return 1
            fi
            git tag -d "$name"
            print_success "Deleted tag '${name}'"
            ;;
        *)
            print_error "Unknown tag action: $action"
            print_info  "Usage: bgit tag [new|delete] [name]"
            ;;
    esac
}

# ─── Command: clean ─────────────────────────────────────────────────────────
cmd_clean() {
    require_git
    require_repo

    local force=false
    [[ "${1:-}" == "-f" || "${1:-}" == "--force" ]] && force=true

    print_header "Cleaning Untracked Files"

    local files
    files=$(git clean -nd 2>/dev/null | sed 's/^Would remove //')

    if [[ -z "$files" ]]; then
        print_success "Nothing to clean. Working tree is already tidy."
        return 0
    fi

    echo -e "  ${BOLD}The following would be removed:${NC}"
    echo "$files" | while IFS= read -r f; do
        echo -e "    ${RED}${CLEAN_ICON}${NC} $f"
    done
    echo

    if [[ "$force" == true ]]; then
        git clean -fd
        print_success "Cleaned."
        return 0
    fi

    local confirm=""
    read -rp "$(echo -e "${YELLOW}${WARN}${NC}  Delete these files? This cannot be undone. [y/N] ")" confirm
    if [[ "${confirm,,}" == "y" ]]; then
        git clean -fd
        print_success "Cleaned."
    else
        print_info "Cancelled."
    fi
}

# ─── Command: sync ──────────────────────────────────────────────────────────
cmd_sync() {
    require_git
    require_repo

    print_header "Syncing with Remote"
    print_step "Pulling latest changes..."
    cmd_pull
    echo
    print_step "Pushing local changes..."
    cmd_push
    print_success "Sync complete!"
}

# ─── Command: undo ──────────────────────────────────────────────────────────
cmd_undo() {
    require_git
    require_repo

    local type="${1:-last}"
    local confirm=""

    case "$type" in
        last|commit)
            print_header "Undoing last commit (keeping changes)"
            git reset --soft HEAD~1
            print_success "Last commit undone. Your changes are staged."
            ;;
        hard)
            print_warn "This will DISCARD all uncommitted changes!"
            read -rp "Are you sure? [y/N] " confirm
            if [[ "${confirm,,}" == "y" ]]; then
                git reset --hard HEAD
                git clean -fd
                print_success "Working tree reset to HEAD."
            else
                print_info "Cancelled."
            fi
            ;;
        add)
            print_header "Unstaging all files"
            git reset HEAD .
            print_success "Files unstaged."
            ;;
        *)
            print_error "Unknown undo type: $type"
            print_info  "Usage: bgit undo [last|hard|add]"
            ;;
    esac
}

# ─── Command: whoami ────────────────────────────────────────────────────────
cmd_whoami() {
    require_git
    require_repo

    local name email branch remote ab a="" b=""
    name=$(git config user.name 2>/dev/null || echo "(not set)")
    email=$(git config user.email 2>/dev/null || echo "(not set)")
    branch=$(current_branch)
    remote=$(git remote get-url origin 2>/dev/null || echo "(none)")

    echo -e "  ${BOLD}${name}${NC} ${DIM}<${email}>${NC}"
    echo -e "  ${BRANCH_ICON} ${branch}$( ab=$(ahead_behind) && { read -r a b <<< "$ab"; [[ "$a" -gt 0 || "$b" -gt 0 ]] && echo -n " ${PUSH_ICON}${a} ${PULL_ICON}${b}"; } )"
    echo -e "  ${DIM}${remote}${NC}"
}

# ─── Command: config ────────────────────────────────────────────────────────
cmd_config() {
    require_git
    require_repo

    print_header "Git Configuration"
    local name email
    name=$(git config user.name 2>/dev/null || echo "(not set)")
    email=$(git config user.email 2>/dev/null || echo "(not set)")

    echo -e "  ${BOLD}user.name:${NC}  $name"
    echo -e "  ${BOLD}user.email:${NC} $email"
    echo -e "  ${BOLD}branch:${NC}     $(current_branch)"
    echo -e "  ${BOLD}remote:${NC}     $(git remote -v 2>/dev/null | head -1 || echo '(none)')"
}

# Compares two dotted version strings. Echoes: gt | lt | eq
version_compare() {
    local v1="$1" v2="$2"
    if [[ "$v1" == "$v2" ]]; then
        echo "eq"
        return
    fi
    local IFS=.
    local -a a=($v1) b=($v2)
    local i
    for ((i=0; i<3; i++)); do
        local x="${a[i]:-0}" y="${b[i]:-0}"
        # strip any non-numeric suffix just in case
        x="${x//[^0-9]/}"; y="${y//[^0-9]/}"
        x="${x:-0}"; y="${y:-0}"
        if ((10#$x > 10#$y)); then echo "gt"; return; fi
        if ((10#$x < 10#$y)); then echo "lt"; return; fi
    done
    echo "eq"
}

# ─── Command: update ────────────────────────────────────────────────────────
cmd_update() {
    local check_only=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) check_only=true; shift ;;
            *) shift ;;
        esac
    done

    print_header "Checking for updates"

    if ! command -v curl &>/dev/null && ! command -v wget &>/dev/null; then
        print_error "Need curl or wget to check for updates, and neither is installed."
        exit 1
    fi

    # Find where the running script actually lives, not a guessed path
    local self_path
    self_path=$(command -v bgit 2>/dev/null || echo "")
    if [[ -z "$self_path" ]]; then
        self_path="${BASH_SOURCE[0]}"
    fi
    # Resolve symlinks so we update the real file
    if command -v readlink &>/dev/null; then
        self_path=$(readlink -f "$self_path" 2>/dev/null || echo "$self_path")
    fi

    if [[ ! -f "$self_path" ]]; then
        print_error "Couldn't figure out where bgit is installed."
        print_info  "Try re-running the installer instead."
        exit 1
    fi

    print_step "Currently installed: ${BOLD}v${VERSION}${NC} (${self_path})"
    print_step "Downloading the latest version..."

    local tmp_file
    tmp_file=$(mktemp)

    if command -v curl &>/dev/null; then
        if ! curl -fsSL "$UPDATE_URL" -o "$tmp_file" 2>/dev/null; then
            print_error "Couldn't reach GitHub to check for updates."
            print_info  "Check your internet connection, or try again in a bit."
            rm -f "$tmp_file"
            exit 1
        fi
    else
        if ! wget -qO "$tmp_file" "$UPDATE_URL" 2>/dev/null; then
            print_error "Couldn't reach GitHub to check for updates."
            rm -f "$tmp_file"
            exit 1
        fi
    fi

    # Strip Windows line endings, same fix as the installer
    sed -i.bak 's/\r$//' "$tmp_file" 2>/dev/null && rm -f "${tmp_file}.bak"

    # Sanity check: does this even look like bgit?
    if ! head -5 "$tmp_file" | grep -q "BGit" ; then
        print_error "The downloaded file doesn't look like a valid BGit script."
        print_info  "Skipping update to be safe — nothing was changed."
        rm -f "$tmp_file"
        exit 1
    fi

    if ! bash -n "$tmp_file" 2>/dev/null; then
        print_error "The downloaded version has a syntax error."
        print_info  "Skipping update to be safe — nothing was changed."
        rm -f "$tmp_file"
        exit 1
    fi

    local remote_version
    remote_version=$(grep -m1 '^VERSION=' "$tmp_file" | sed -E 's/VERSION="([^"]*)"/\1/')
    remote_version="${remote_version:-unknown}"

    local cmp
    cmp=$(version_compare "$remote_version" "$VERSION")

    if [[ "$cmp" == "eq" ]]; then
        print_success "You're already on the latest version (v${VERSION})."
        rm -f "$tmp_file"
        return 0
    fi

    if [[ "$cmp" == "lt" ]]; then
        print_success "You're running v${VERSION}, which is newer than what's published (v${remote_version})."
        print_dim "  Nothing to do — you're ahead of the curve."
        rm -f "$tmp_file"
        return 0
    fi

    echo
    print_info "New version available: ${BOLD}v${VERSION}${NC} → ${BOLD}${GREEN}v${remote_version}${NC}"

    if [[ "$check_only" == true ]]; then
        print_info "Run ${BOLD}bgit update${NC} (without --check) to install it."
        rm -f "$tmp_file"
        return 0
    fi

    # Back up the current version before touching anything
    local backup_path="${self_path}.bak"
    cp "$self_path" "$backup_path" 2>/dev/null || {
        print_error "Couldn't create a backup at ${backup_path} — aborting to be safe."
        rm -f "$tmp_file"
        exit 1
    }
    print_step "Backed up current version to ${DIM}${backup_path}${NC}"

    chmod +x "$tmp_file"

    if [[ -w "$self_path" ]]; then
        mv "$tmp_file" "$self_path"
    else
        print_step "Need elevated permissions to write to ${self_path}..."
        sudo mv "$tmp_file" "$self_path" 2>/dev/null || {
            print_error "Couldn't write to ${self_path}, even with sudo."
            print_info  "Your old version is safe and untouched."
            rm -f "$tmp_file"
            exit 1
        }
        sudo chmod +x "$self_path" 2>/dev/null || true
    fi

    print_success "Updated to ${BOLD}v${remote_version}${NC}! 🎉"
    print_dim "  Old version backed up at ${backup_path} (delete it anytime)"
    print_dim "  Run 'bgit version' to confirm."
}

# ─── Command: version ───────────────────────────────────────────────────────
cmd_version() {
    echo -e "${BOLD}${PURPLE}BGit${NC} version ${GREEN}${VERSION}${NC}"
    echo -e "${DIM}Better Git — a friendlier git wrapper${NC}"
    echo -e "${DIM}https://github.com/connorgentile113-png/BGit${NC}"
    echo -e "${DIM}Run 'bgit update' to check for the latest version.${NC}"
}

# ─── Command: help ──────────────────────────────────────────────────────────
cmd_help() {
    echo -e "${BOLD}${PURPLE}"
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║          BGit — Better Git           ║"
    echo "  ╚══════════════════════════════════════╝"
    echo -e "${NC}"
    echo -e "  ${BOLD}A cleaner, friendlier wrapper around git.${NC}"
    echo
    echo -e "  ${BOLD}${CYAN}USAGE${NC}"
    echo -e "    bgit <command> [options]"
    echo
    echo -e "  ${BOLD}${CYAN}EVERYDAY${NC}"
    echo -e "    ${BOLD}status${NC} [-s]       Show repo state (-s for one-line summary)"
    echo -e "    ${BOLD}diff${NC} [--staged]   Show a clean change summary"
    echo -e "    ${BOLD}add${NC} [file|.]      Stage files (default: all)"
    echo -e "    ${BOLD}commit${NC} [-m msg]   Commit staged changes (auto-generates message)"
    echo -e "    ${BOLD}amend${NC} [-m msg]    Amend the last commit"
    echo -e "    ${BOLD}push${NC} [-f]         Push to remote (auto-sets upstream)"
    echo -e "    ${BOLD}pull${NC}              Pull from remote (auto-stashes, auto-resolves)"
    echo -e "    ${BOLD}sync${NC}              Pull + push in one step"
    echo
    echo -e "  ${BOLD}${CYAN}BRANCHES${NC}"
    echo -e "    ${BOLD}branch${NC} [action]   List/create/delete/switch branches"
    echo -e "    ${BOLD}recent${NC} [n]        Recently visited branches"
    echo -e "    ${BOLD}merge${NC} <branch>    Merge a branch (auto-resolves conflicts)"
    echo -e "    ${BOLD}resolve${NC} [strategy] Auto-resolve merge conflicts"
    echo
    echo -e "  ${BOLD}${CYAN}HISTORY & CLEANUP${NC}"
    echo -e "    ${BOLD}log${NC} [n]           Show recent commits (default: 15)"
    echo -e "    ${BOLD}stash${NC} [action]    Save/pop/list stashed changes"
    echo -e "    ${BOLD}tag${NC} [action]      List/create/delete tags"
    echo -e "    ${BOLD}clean${NC} [-f]        Remove untracked files (asks first)"
    echo -e "    ${BOLD}undo${NC} [type]       Undo last commit / hard reset / unstage"
    echo
    echo -e "  ${BOLD}${CYAN}SETUP & INFO${NC}"
    echo -e "    ${BOLD}init${NC}              Initialize a new Git repository"
    echo -e "    ${BOLD}clone${NC} <url>       Clone a repository"
    echo -e "    ${BOLD}whoami${NC}            Quick identity + branch + remote summary"
    echo -e "    ${BOLD}config${NC}            Show git configuration"
    echo -e "    ${BOLD}update${NC} [--check]  Update bgit to the latest version"
    echo -e "    ${BOLD}version${NC}           Show BGit version"
    echo -e "    ${BOLD}help${NC}              Show this help message"
    echo
    echo -e "  ${BOLD}${CYAN}CONFLICT RESOLUTION STRATEGIES${NC}"
    echo -e "    ${BOLD}--ours${NC}           Keep your local changes"
    echo -e "    ${BOLD}--theirs${NC}         Keep incoming/remote changes"
    echo -e "    ${BOLD}--union${NC}          Combine both sides"
    echo -e "    ${BOLD}--auto${NC}           Auto-resolve (defaults to --ours)"
    echo
    echo -e "  ${BOLD}${CYAN}EXAMPLES${NC}"
    echo -e "    ${DIM}# Start a new project${NC}"
    echo -e "    bgit init && bgit add . && bgit commit -m \"Initial commit\""
    echo
    echo -e "    ${DIM}# Quick glance before standup${NC}"
    echo -e "    bgit status -s"
    echo
    echo -e "    ${DIM}# Resolve conflicts keeping your changes${NC}"
    echo -e "    bgit resolve --ours"
    echo
    echo -e "    ${DIM}# Full sync with remote${NC}"
    echo -e "    bgit sync"
    echo
    echo -e "    ${DIM}# Stay current${NC}"
    echo -e "    bgit update --check    ${DIM}# just check, don't install${NC}"
    echo -e "    bgit update             ${DIM}# install the latest version${NC}"
    echo
    echo -e "  ${BOLD}${CYAN}PASS-THROUGH${NC}"
    echo -e "    Any unrecognized command is passed directly to ${BOLD}git${NC}."
    echo -e "    ${DIM}bgit rebase -i HEAD~3${NC}  →  ${DIM}git rebase -i HEAD~3${NC}"
    echo
    echo -e "  ${DIM}Set NO_COLOR=1 to disable colored output.${NC}"
    echo
}

# ─── Main Entry Point ───────────────────────────────────────────────────────
main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        init)       cmd_init "$@" ;;
        status|st)  cmd_status "$@" ;;
        diff|d)     cmd_diff "$@" ;;
        add)        cmd_add "$@" ;;
        commit|ci)  cmd_commit "$@" ;;
        amend)      cmd_amend "$@" ;;
        push)       cmd_push "$@" ;;
        pull)       cmd_pull "$@" ;;
        merge)      cmd_merge "$@" ;;
        resolve)    cmd_resolve "$@" ;;
        clone)      cmd_clone "$@" ;;
        branch|br)  cmd_branch "$@" ;;
        recent)     cmd_recent "$@" ;;
        log)        cmd_log "$@" ;;
        stash)      cmd_stash "$@" ;;
        tag)        cmd_tag "$@" ;;
        clean)      cmd_clean "$@" ;;
        sync)       cmd_sync "$@" ;;
        undo)       cmd_undo "$@" ;;
        whoami)     cmd_whoami "$@" ;;
        config)     cmd_config "$@" ;;
        update)     cmd_update "$@" ;;
        version|-v|--version) cmd_version "$@" ;;
        help|-h|--help) cmd_help "$@" ;;
        *)
            require_git
            git "$command" "$@"
            ;;
    esac
}

main "$@"
